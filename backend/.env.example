# Server
FASTIFY_PORT=3001
FASTIFY_ADDRESS=127.0.0.1
LOG_LEVEL=info

# Database (local dev)
DATABASE_URL=postgresql://devuser:devpass@localhost:5432/app

# Database (Cloud SQL / GCP production)
# CLOUDSQL_CONNECTION=project:region:instance
# DB_IAM_USER=user@project.iam.gserviceaccount.com
# DB_NAME=app

# CORS (optional — defaults to reflecting request origin)
# CORS_ORIGIN=https://myapp.example.com

# Better Auth
# Use `openssl rand -base64 32` to generate a secure random secret for production
BETTER_AUTH_SECRET=change-me-local-dev-secret
BETTER_AUTH_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (https://developer.apple.com/account/resources)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
